*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.installed.cfg
MANIFEST

# ── Virtual environments ──────────────────────────────────
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
backend/venv/

# ── Distribution / Build ──────────────────────────────────
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/

# ── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Linting / Typing / Testing ───────────────────────────
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Generated assets ─────────────────────────────────────
assets/icon.ico

